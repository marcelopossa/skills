# Required for DeepSeek-powered classification, dependency analysis, and description refinement.
# Generate at https://platform.deepseek.com/
DEEPSEEK_API_KEY=

# Optional. Used for GitHub API calls.
# Without a token: anonymous rate limit (60 req/h, can throttle).
# With a token: 5000 req/h. Fine-grained token, read-only on public repos is enough.
# Create at https://github.com/settings/tokens
GITHUB_TOKEN=
